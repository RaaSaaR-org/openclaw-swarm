---
import Base from '~/layouts/Base.astro';
import { loadCatalog } from '~/data/catalog';

const apps = loadCatalog();
const categories = Array.from(new Set(apps.map((a) => a.category))).sort();
---
<Base title="Apps" description="Browse the Kai app catalog — personal assistant, coding helper, writing coach, language tutor, study buddy, productivity companion.">
  <h1>Apps</h1>
  <p>
    Each app is a curated persona — a SOUL profile, recommended model, and
    starter prompts. Pick one at signup; switch any time without losing your
    workspace.
  </p>

  {categories.map((cat) => (
    <section>
      <h2 style="text-transform:capitalize;">{cat}</h2>
      <div class="card-grid">
        {apps.filter((a) => a.category === cat).map((app) => (
          <article class="card">
            <div class="icon" set:html={app.iconSvg}></div>
            <h3>{app.name}</h3>
            <div class="meta">{app.category} · {app.tier} · {app.toolsProfile}</div>
            <p>{app.shortDescription}</p>
            <span class="tier">Starts on the <strong>{app.tier}</strong> tier</span>
          </article>
        ))}
      </div>
    </section>
  ))}
</Base>
