<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>Confirm your email</title></head>
<body style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#141414;color:#eee;margin:0;padding:24px;">
  <div style="max-width:520px;margin:0 auto;background:#1f1f1f;padding:32px;border-radius:8px;">
    <h1 style="color:#FF6700;margin:0 0 16px;font-size:22px;">Welcome to Mind Swarm</h1>
    <p style="margin:0 0 16px;line-height:1.5;">Hi {{.Name}},</p>
    <p style="margin:0 0 16px;line-height:1.5;">please confirm your email address so you can get started:</p>
    <p style="margin:24px 0;">
      <a href="{{.VerifyURL}}" style="background:#FF6700;color:#fff;padding:12px 24px;border-radius:6px;text-decoration:none;display:inline-block;">Confirm email</a>
    </p>
    <p style="margin:0 0 16px;line-height:1.5;color:#aaa;font-size:13px;">If the button doesn't work, paste this link in your browser:<br><span style="word-break:break-all;">{{.VerifyURL}}</span></p>
    <p style="margin:24px 0 0;line-height:1.5;color:#aaa;font-size:13px;">The link expires in {{.ExpiresInHours}} hours.</p>
  </div>
</body>
</html>
