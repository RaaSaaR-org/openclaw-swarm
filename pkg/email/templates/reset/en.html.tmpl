<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>Reset your password</title></head>
<body style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#141414;color:#eee;margin:0;padding:24px;">
  <div style="max-width:520px;margin:0 auto;background:#1f1f1f;padding:32px;border-radius:8px;">
    <h1 style="color:#FF6700;margin:0 0 16px;font-size:22px;">Reset your password</h1>
    <p style="margin:0 0 16px;line-height:1.5;">Hi {{.Name}},</p>
    <p style="margin:0 0 16px;line-height:1.5;">you asked to reset your password. Click the link below to set a new one:</p>
    <p style="margin:24px 0;">
      <a href="{{.ResetURL}}" style="background:#FF6700;color:#fff;padding:12px 24px;border-radius:6px;text-decoration:none;display:inline-block;">Reset password</a>
    </p>
    <p style="margin:0 0 16px;line-height:1.5;color:#aaa;font-size:13px;">If the button doesn't work, paste this link in your browser:<br><span style="word-break:break-all;">{{.ResetURL}}</span></p>
    <p style="margin:24px 0 0;line-height:1.5;color:#aaa;font-size:13px;">The link expires in {{.ExpiresInHours}} hours. If you didn't request a reset, just ignore this email &mdash; your password stays the same.</p>
  </div>
</body>
</html>
