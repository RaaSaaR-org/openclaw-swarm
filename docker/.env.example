# Image tag: main-slim (dev) or latest (production, includes browser)
OPENCLAW_TAG=main-slim

# OpenRouter API key (free tier available at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model (free tier options)
# stepfun/step-3.5-flash:free
# google/gemma-2-9b-it:free
OPENCLAW_MODEL=openrouter/stepfun/step-3.5-flash:free

# Telegram bot token (optional, create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Gateway ports (host-side)
CENTRAL_GATEWAY_PORT=18789
DEMO_A_GATEWAY_PORT=18790
DEMO_B_GATEWAY_PORT=18791
