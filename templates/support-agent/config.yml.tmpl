# {{CUSTOMER_NAME}} — Customer Configuration
# This file tracks which features and channels are enabled for this customer.
# Used by deploy.sh, swarm-sync, and operator provisioning.

customer:
  name: "{{CUSTOMER_NAME}}"
  slug: "{{CUSTOMER_SLUG}}"
  hq_id: "{{HQ_ID}}"
  project: "{{PROJECT_NAME}}"
  language: "{{LANGUAGE}}"
  status: "active"

# Features enabled for this customer
features:
  openclaw: true              # Base: isolated Kai agent instance
  project-management: false   # No MissionControl for support agents

# Communication channels
channels:
  webchat:
    enabled: true
    url: "https://kai.emai.dev/chat/{{CUSTOMER_SLUG}}"
  # telegram:
  #   enabled: false
