apiVersion: swarm.emai.io/v1alpha2
kind: KaiInstance
metadata:
  name: kai-{{CUSTOMER_SLUG}}
  namespace: emai-swarm
spec:
  tenantName: "{{CUSTOMER_NAME}}"
  projectName: "{{PROJECT_NAME}}"
  tenantSlug: "{{CUSTOMER_SLUG}}"
  gatewayAuth:
    mode: "token"
    token: "{{GATEWAY_TOKEN}}"
  resources:
    requests:
      memory: "1Gi"
      cpu: "100m"
    limits:
      memory: "2Gi"
      cpu: "500m"
